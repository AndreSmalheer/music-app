# Kopieer dit bestand naar .env en vul je eigen waarden in.
# .env wordt NOOIT gecommit.

MONGODB_URI=mongodb://localhost:27017/muziekapp
PORT=3001

# Optioneel — alleen nodig als je de YouTube Data API gebruikt voor zoeken/metadata
YOUTUBE_API_KEY=

# Optioneel — volledig pad naar de yt-dlp executable.
# Leeg laten als 'yt-dlp' op je PATH staat. Installeren: pip install -U yt-dlp
YTDLP_PATH=
